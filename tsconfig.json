{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "lib/typescript",
    "rootDir": "src",
    "paths": {
      "react-native": ["./node_modules/react-native"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib", "example"]
}
