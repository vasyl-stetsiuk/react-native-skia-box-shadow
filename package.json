{
  "name": "react-native-skia-box-shadow",
  "version": "0.2.0",
  "description": "CSS-style box shadows for React Native — blur, spread, offset, colors, gradients, and arbitrary shapes. Powered by @shopify/react-native-skia.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rm -rf lib",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "skia",
    "shadow",
    "box-shadow",
    "drop-shadow",
    "blur",
    "spread",
    "ios",
    "android",
    "react-native-skia",
    "animated",
    "reanimated"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vasyl-stetsiuk/react-native-skia-box-shadow.git"
  },
  "author": {
    "name": "Vasyl Stetsiuk",
    "url": "https://stetsiuk.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vasyl-stetsiuk/react-native-skia-box-shadow/issues"
  },
  "homepage": "https://github.com/vasyl-stetsiuk/react-native-skia-box-shadow#readme",
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-reanimated": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@shopify/react-native-skia": {
      "optional": false
    },
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@shopify/react-native-skia": "^1.11.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "react": "^18.2.0",
    "react-native": "^0.75.0",
    "react-native-builder-bob": "^0.30.0",
    "react-native-reanimated": "^3.16.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
